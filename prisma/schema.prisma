// Shuttle Smash Championship 2026 — data model
// One fixed Tournament row ("main") holds the minimal bracket state as JSON.
// Teams stay normalized so names/seeds are editable and referenced by stable IDs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  player1   String
  player2   String
  seed      Int? // 1..10 once seeded; null before
  createdAt DateTime @default(now())

  @@index([seed])
}

model Tournament {
  id        String   @id @default("main")
  name      String   @default("Shuttle Smash Championship 2026")
  // The whole bracket lives in this JSON column (the tree is derived on read):
  // state = {
  //   seededTeamIds: string[];                         // seed order
  //   results: Record<matchId, winnerTeamId>;          // who advanced
  //   scores:  Record<matchId, { a: number, b: number }>; // per-match score
  //   thirdPlace: boolean;
  // }
  state     Json     @default("{\"seededTeamIds\":[],\"results\":{},\"scores\":{},\"thirdPlace\":true}")
  updatedAt DateTime @updatedAt
}
