// Shuttle Smash Championship 2026 — data model
// One fixed Tournament row ("main") holds the minimal bracket state as JSON.
// Teams stay normalized so names/seeds are editable and referenced by stable IDs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  player1   String
  player2   String
  seed      Int? // 1..10 once seeded; null before
  createdAt DateTime @default(now())

  @@index([seed])
}

model Tournament {
  id        String   @id @default("main")
  name      String   @default("Shuttle Smash Championship 2026")
  // The whole tournament lives in this JSON column (standings/playoffs derived on read):
  // state = {
  //   tableA: string[];  // ordered team ids in group Table A
  //   tableB: string[];  // ordered team ids in group Table B
  //   results: Record<matchId, winnerTeamId>;             // who won each match
  //   scores:  Record<matchId, { a: number, b: number }>; // per-match score
  // }
  state     Json     @default("{\"tableA\":[],\"tableB\":[],\"results\":{},\"scores\":{}}")
  updatedAt DateTime @updatedAt
}
