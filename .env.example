# Copy this file to `.env` and fill in real values. `.env` is gitignored — never commit secrets.

# Prisma Postgres connection string (Accelerate-pooled).
# Get it from the Vercel Storage marketplace or the Prisma Data Platform.
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=__REPLACE_ME__"

# The single admin login password (used to update the bracket).
ADMIN_PASSWORD="__set-a-strong-password__"

# Secret used to HMAC-sign the admin session cookie.
# Generate one with:  openssl rand -hex 32
ADMIN_SESSION_SECRET="__random-32-byte-hex__"
